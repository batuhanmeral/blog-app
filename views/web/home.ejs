<%- include('partials/header') %>

    <style>
    .post-tags-mini { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:10px; }
    .tag-mini { display:inline-block; padding:3px 10px; border-radius:12px; font-size:11px; color:#fff; text-decoration:none; transition: opacity .2s; }
    .tag-mini:hover { opacity: .8; }
    .blog-card { cursor: pointer; }
    .blog-card h3 a { pointer-events: none; }
    </style>

    <section class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <h1 class="animate-text glitch" data-text="Crypton">Crypton</h1>
            <p class="animate-text delay typing-cursor"><%= t('home.hero_subtitle') %></p>
            <div class="hero-btns animate-text delay-2">
                <a href="/about" class="btn btn-primary"><%= t('home.btn_about') %></a>
                <a href="#blog" class="btn btn-outline"><%= t('home.btn_explore') %></a>
            </div>
        </div>
    </section>

    <main class="container" id="blog">
        <div class="section-header">
            <h2 class="section-title"><%= t('home.latest') %></h2>
        </div>

        <div class="blog-grid">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <article class="blog-card" data-href="/blog/<%= post._id %>">
                        <div class="card-img-holder">
                            <img src="<%= post.image %>" alt="<%= post.imageAlt || post.title %>" loading="lazy">
                        </div>
                        <div class="card-content">
                            <div class="meta">
                                <span><i class="far fa-calendar"></i> <%= helpers.formatDate(post.createdAt) %></span>
                                <span><i class="far fa-clock"></i> <%= post.readTime || 5 %> <%= t('common.minread') %></span>
                            </div>
                            <h3><a href="/blog/<%= post._id %>"><%= post.title %></a></h3>
                            <% if (post.categories && post.categories.length > 0) { %>
                            <div class="post-tags-mini">
                                <% post.categories.forEach(cat => { %>
                                <a href="/blog?category=<%= cat.slug %>" class="tag-mini" style="background-color: <%= cat.color %>" data-stop-propagation="1"><%= cat.name %></a>
                                <% }); %>
                            </div>
                            <% } %>
                            <p><%= post.summary %></p>
                            <span class="read-more"><%= t('common.readmore') %> <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; color: var(--text-muted);"><%= t('blog.empty') %></p>
            <% } %>
        </div>
    </main>

    <script nonce="<%= cspNonce %>">
    document.querySelectorAll('[data-stop-propagation]').forEach(el => {
        el.addEventListener('click', e => e.stopPropagation());
    });
    document.querySelectorAll('.blog-card[data-href]').forEach(card => {
        card.addEventListener('click', e => {
            if (!e.target.closest('.tag-mini')) window.location.href = card.dataset.href;
        });
    });
    </script>

    <%- include('partials/footer') %>
