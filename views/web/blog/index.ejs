<%- include('../partials/header') %>

    <style nonce="<%= cspNonce %>">
    .post-tags-mini { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:10px; }
    .tag-mini { display:inline-block; padding:3px 10px; border-radius:12px; font-size:11px; color:#fff; text-decoration:none; transition: opacity .2s; }
    .tag-mini:hover { opacity: .8; }
    .tag-mini--plain { background: rgba(255,255,255,0.08); color: var(--text-muted); }
    .filter-note { text-align:center; color: var(--text-muted); margin: 4px 0 20px; }
    .filter-note a { color: var(--primary-color); }
    .blog-card { cursor: pointer; }
    .blog-card h3 a { pointer-events: none; }
    </style>

    <section class="page-header">
        <div class="container">
            <h1 class="animate-text glitch" data-text="<%= t('blog.title') %>"><%= t('blog.title') %></h1>
            <p class="animate-text delay typing-cursor"><%= t('blog.subtitle') %></p>
        </div>
    </section>

    <main class="container">
        <form class="search-container animate-text delay" action="/blog" method="GET" role="search">
            <i class="fas fa-search search-icon"></i>
            <input type="text" name="q" id="search-input" class="search-input" value="<%= locals.searchQuery || '' %>"
                placeholder="<%= t('blog.search_ph') %>">
        </form>

        <% if (locals.searchQuery) { %>
            <p class="filter-note"><%= t('blog.results', { q: searchQuery, n: posts.length }) %> · <a href="/blog"><%= t('blog.clear') %></a></p>
        <% } else if (locals.activeTag) { %>
            <p class="filter-note"><%= t('blog.tag_results', { tag: activeTag, n: posts.length }) %> · <a href="/blog"><%= t('blog.clear') %></a></p>
        <% } %>

        <div class="filter-container animate-text delay">
            <a href="/blog" class="filter-btn <%= (!activeCategory && !locals.activeTag && !locals.searchQuery) ? 'active' : '' %>"><%= t('blog.all') %></a>
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach(cat => { %>
                    <a href="/blog?category=<%= cat.slug %>"
                       class="filter-btn <%= activeCategory && activeCategory._id && String(activeCategory._id) === String(cat._id) ? 'active' : '' %>"
                       style="<%= activeCategory && activeCategory._id && String(activeCategory._id) === String(cat._id) ? 'background-color:' + cat.color + '; border-color:' + cat.color : '' %>">
                        <%= cat.name %>
                    </a>
                <% }); %>
            <% } %>
        </div>

        <div class="blog-grid animate-text delay-2" id="blog-grid-container">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <article class="blog-card" data-href="/blog/<%= post._id %>">
                        <div class="card-img-holder">
                            <img src="<%= post.image %>" alt="<%= post.imageAlt || post.title %>" loading="lazy">
                        </div>
                        <div class="card-content">
                            <div class="meta">
                                <span><i class="far fa-calendar"></i> <%= helpers.formatDate(post.createdAt) %></span>
                                <span><i class="far fa-clock"></i> <%= post.readTime || 5 %> <%= t('common.minread') %></span>
                            </div>
                            <h3><a href="/blog/<%= post._id %>"><%= post.title %></a></h3>
                            <% if (post.categories && post.categories.length > 0) { %>
                            <div class="post-tags-mini">
                                <% post.categories.forEach(cat => { %>
                                <a href="/blog?category=<%= cat.slug %>" class="tag-mini" style="background-color: <%= cat.color %>" data-stop-propagation="1"><%= cat.name %></a>
                                <% }); %>
                            </div>
                            <% } %>
                            <p><%= post.summary %></p>
                            <% if (post.tags && post.tags.length > 0) { %>
                            <div class="post-tags-mini">
                                <% post.tags.forEach(tg => { %>
                                <a href="/tag/<%= encodeURIComponent(tg) %>" class="tag-mini tag-mini--plain" data-stop-propagation="1">#<%= tg %></a>
                                <% }); %>
                            </div>
                            <% } %>
                            <span class="read-more"><%= t('common.readmore') %> <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; color: var(--text-muted);"><%= locals.searchQuery ? t('blog.no_results') : t('blog.empty') %></p>
            <% } %>
        </div>
    </main>

    <script nonce="<%= cspNonce %>">
        document.querySelectorAll('[data-stop-propagation]').forEach(el => {
            el.addEventListener('click', e => e.stopPropagation());
        });

        document.querySelectorAll('.blog-card[data-href]').forEach(card => {
            card.addEventListener('click', e => {
                if (!e.target.closest('.tag-mini')) window.location.href = card.dataset.href;
            });
        });
    </script>

    <%- include('../partials/footer') %>
