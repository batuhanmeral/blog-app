<%- include('../partials/header') %>

    <style>
    .post-tags-mini {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
    }
    .tag-mini {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 11px;
        color: #fff;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .tag-mini:hover {
        opacity: 0.8;
    }
    .blog-card {
        cursor: pointer;
    }
    .blog-card h3 a {
        pointer-events: none;
    }
    </style>

    <section class="page-header">
        <div class="container">
            <h1 class="animate-text glitch" data-text="Makaleler">Makaleler</h1>
            <p class="animate-text delay typing-cursor">Siber güvenlik üzerine makaleler.</p>
        </div>
    </section>

    <main class="container">
        <div class="search-container animate-text delay">
            <i class="fas fa-search search-icon"></i>
            <input type="text" id="search-input" class="search-input"
                placeholder="Makale ara... (örn: Web güvenliği, Ağ güvenliği)">
        </div>

        <div class="filter-container animate-text delay">
            <a href="/blog" class="filter-btn <%= !activeCategory ? 'active' : '' %>">Tümü</a>
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach(cat => { %>
                    <a href="/blog?category=<%= cat.slug %>" 
                       class="filter-btn <%= activeCategory && activeCategory.id === cat.id ? 'active' : '' %>"
                       style="<%= activeCategory && activeCategory.id === cat.id ? 'background-color:' + cat.color + '; border-color:' + cat.color : '' %>">
                        <%= cat.name %>
                    </a>
                <% }); %>
            <% } %>
        </div>

        <div class="blog-grid animate-text delay-2" id="blog-grid-container">
            <% if (posts.length> 0) { %>
                <% posts.forEach(post=> { %>
                    <article class="blog-card" data-href="/blog/<%= post.id %>">>
                        <div class="card-img-holder">
                            <img src="<%= post.image %>" alt="<%= post.title %>">
                        </div>
                        <div class="card-content">
                            <div class="meta">
                                <span><i class="far fa-calendar"></i>
                                    <%= new Date(post.date).toLocaleDateString('tr-TR') %>
                                </span>
                                <span><i class="far fa-user"></i>
                                    <%= post.User ? (post.User.name || post.User.username) : 'Anonim' %>
                                </span>
                                <span><i class="far fa-clock"></i> <%= post.readTime || 5 %> dk oku</span>
                            </div>
                            <h3><a href="/blog/<%= post.id %>">
                                    <%= post.title %>
                                </a></h3>
                            <% if (post.Categories && post.Categories.length > 0) { %>
                            <div class="post-tags-mini">
                                <% post.Categories.forEach(cat => { %>
                                <a href="/blog?category=<%= cat.slug %>" class="tag-mini" style="background-color: <%= cat.color %>" onclick="event.stopPropagation();"><%= cat.name %></a>
                                <% }); %>
                            </div>
                            <% } %>
                            <p>
                                <%= post.summary %>
                            </p>
                            <span class="read-more">Devamını Oku <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </article>
                    <% }) %>
                        <% } else { %>
                            <p style="text-align:center; color: var(--text-muted);">Henüz yazı eklenmemiş.</p>
                            <% } %>
        </div>
    </main>

    <script>
        const searchInput = document.getElementById('search-input');
        const blogGrid = document.getElementById('blog-grid-container');
        const cards = document.querySelectorAll('.blog-card');

        if (searchInput) {
            searchInput.addEventListener('input', function (e) {
                const term = e.target.value.toLowerCase();
                cards.forEach(card => {
                    const title = card.querySelector('h3 a').innerText.toLowerCase();
                    const summary = card.querySelector('p').innerText.toLowerCase();
                    if (title.includes(term) || summary.includes(term)) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        }

        // Kartlara tıklama
        document.querySelectorAll('.blog-card[data-href]').forEach(card => {
            card.addEventListener('click', function(e) {
                if (!e.target.closest('.tag-mini')) {
                    window.location.href = this.dataset.href;
                }
            });
        });
    </script>

    <%- include('../partials/footer') %>