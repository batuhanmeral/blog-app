<%- include('../partials/header') %>

    <main class="container" style="margin-top: 120px;">
        <div class="about-grid">
            <div class="about-img">
                <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=600&q=80"
                    alt="Batuhan Meral">
            </div>
            <div class="about-text">
                <h1 class="section-title glitch" data-text="<%= t('about.title') %>"><%= t('about.title') %></h1>
                <p><%- t('about.p1') %></p>
                <p><%= t('about.p2') %></p>

                <h3 style="margin-top: 30px; margin-bottom: 15px;"><%= t('about.focus') %></h3>
                <div class="skills-wrapper">
                    <span class="skill-tag"><%= t('about.skill_web') %></span>
                    <span class="skill-tag"><%= t('about.skill_net') %></span>
                    <span class="skill-tag"><%= t('about.skill_ctf') %></span>
                    <span class="skill-tag"><%= t('about.skill_zeroday') %></span>
                    <span class="skill-tag"><%= t('about.skill_crypto') %></span>
                    <span class="skill-tag"><%= t('about.skill_bugbounty') %></span>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>