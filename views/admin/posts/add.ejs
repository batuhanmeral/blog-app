<%- include('../partials/header') %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>

    <style>
        .EasyMDEContainer {
            background: transparent;
        }

        .editor-toolbar {
            background: #1e293b;
            border-color: #334155;
            color: #fff;
        }

        .editor-toolbar i {
            color: #e2e8f0;
        }

        .editor-toolbar i.active,
        .editor-toolbar i:hover {
            background: #334155;
            border-color: #475569;
        }

        .CodeMirror {
            background: #0f172a;
            color: #e2e8f0;
            border-color: #334155;
        }

        .editor-preview {
            background: #0f172a;
            color: #e2e8f0;
        }

        .editor-statusbar {
            color: #94a3b8;
        }
    </style>

    <main class="container admin-main" style="max-width: 900px;">
        <div class="section-header">
            <h2 class="section-title">Yeni Yazı Ekle</h2>
        </div>

        <div class="contact-card">
            <form action="/admin/posts/add" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" name="title" required>
                </div>

                <div class="form-group">
                    <label>Özet</label>
                    <textarea name="summary" rows="3" required></textarea>
                </div>

                <% if (categories && categories.length > 0) { %>
                <div class="form-group">
                    <label>Kategoriler</label>
                    <div class="tags-checkbox-group">
                        <% categories.forEach(cat => { %>
                        <label class="tag-checkbox">
                            <input type="checkbox" name="categories" value="<%= cat.id %>">
                            <span class="tag-label" style="background-color: <%= cat.color %>"><%= cat.name %></span>
                        </label>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <div class="form-group">
                    <label>Kapak Resmi</label>
                    <input type="file" name="image" accept="image/*"
                        style="margin-bottom: 10px; width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                    <input type="text" name="image" placeholder="Veya Resim URL'si">
                </div>

                <div class="form-group">
                    <label>İçerik (Markdown)</label>
                    <textarea id="post-content" name="content"></textarea>
                </div>

                <details class="seo-settings" style="margin-bottom: 20px;">
                    <summary style="cursor: pointer; padding: 15px; background: rgba(255,255,255,0.03); border-radius: 8px; font-weight: 600;">
                        <i class="fas fa-search"></i> SEO Ayarları (Opsiyonel)
                    </summary>
                    <div style="padding: 20px; background: rgba(255,255,255,0.02); border-radius: 0 0 8px 8px;">
                        <div class="form-group">
                            <label>SEO Başlık <small style="color: var(--text-muted);">(max 70 karakter)</small></label>
                            <input type="text" name="seoTitle" maxlength="70" placeholder="Arama motorlarında görünecek başlık">
                        </div>
                        <div class="form-group">
                            <label>SEO Açıklama <small style="color: var(--text-muted);">(max 160 karakter)</small></label>
                            <textarea name="seoDescription" rows="2" maxlength="160" placeholder="Meta description - arama sonuçlarında görünür"></textarea>
                        </div>
                        <div class="form-group">
                            <label>Anahtar Kelimeler</label>
                            <input type="text" name="seoKeywords" placeholder="kelime1, kelime2, kelime3">
                        </div>
                        <div class="form-group">
                            <label>Open Graph Görseli (Sosyal medya paylaşımları için)</label>
                            <input type="text" name="ogImage" placeholder="https://... veya /assets/uploads/...">
                        </div>
                    </div>
                </details>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Yayınla</button>
            </form>
        </div>
    </main>

    <script>
        const easyMDE = new EasyMDE({
            element: document.getElementById('post-content'),
            spellChecker: false,
            placeholder: "İçeriğinizi buraya yazın (Markdown destekler)...",
            toolbar: ["bold", "italic", "heading", "|", "quote", "unordered-list", "ordered-list", "|", "link", "image", "|", "preview", "side-by-side", "fullscreen", "|", "guide"]
        });

        easyMDE.codemirror.on("drop", function (editor, e) {
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                e.preventDefault();
                uploadImage(files[0]);
            }
        });

        easyMDE.codemirror.on("paste", function (editor, e) {
            const items = e.clipboardData.items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    e.preventDefault();
                    uploadImage(items[i].getAsFile());
                }
            }
        });

        function uploadImage(file) {
            const formData = new FormData();
            formData.append("file", file);

            const pos = easyMDE.codemirror.getCursor();
            easyMDE.codemirror.replaceRange("![Resim Yükleniyor...]()", pos);

            fetch("/admin/upload-image", {
                method: "POST",
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    const content = easyMDE.value();
                    const newContent = content.replace("![Resim Yükleniyor...]()", `![](${data.location})`);
                    easyMDE.value(newContent);
                })
                .catch(error => {
                    console.error("Error:", error);
                    alert("Resim yüklenirken hata oluştu.");
                });
        }
    </script>

    <style>
    .tags-checkbox-group {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .tag-checkbox {
        display: flex;
        align-items: center;
        cursor: pointer;
    }
    .tag-checkbox input[type="checkbox"] {
        display: none;
    }
    .tag-checkbox .tag-label {
        padding: 6px 14px;
        border-radius: 20px;
        color: #fff;
        font-size: 13px;
        font-weight: 500;
        opacity: 0.5;
        transition: all 0.2s;
    }
    .tag-checkbox input[type="checkbox"]:checked + .tag-label {
        opacity: 1;
        box-shadow: 0 0 0 2px #fff;
    }
    </style>

<%- include('../partials/footer') %>