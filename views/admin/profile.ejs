<%- include('partials/header') %>

    <main class="container admin-main" style="max-width: 600px;">
        <div class="section-header">
            <h2 class="section-title"><%= t('a.prof_title') %></h2>
        </div>

        <% if (locals.flash && flash.success) { %>
            <div style="background: rgba(16,185,129,.1); border:1px solid #10b981; color:#10b981; padding:10px; border-radius:8px; margin-bottom:15px;"><%= flash.success %></div>
        <% } %>
        <% if (locals.flash && flash.error) { %>
            <div style="background: rgba(239,68,68,.1); border:1px solid #ef4444; color:#ef4444; padding:10px; border-radius:8px; margin-bottom:15px;"><%= flash.error %></div>
        <% } %>

        <% if (user && user.mustChangePassword) { %>
            <div style="background: rgba(251,146,60,.12); border:1px solid #fb923c; color:#fb923c; padding:12px; border-radius:8px; margin-bottom:15px;">
                <strong><%= t('a.prof_must_change') %></strong> <%= t('a.prof_must_change_desc') %>
            </div>
        <% } %>

        <div class="contact-card">
            <form action="/admin/profile" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="form-group">
                    <label><%= t('a.prof_name') %></label>
                    <input type="text" name="name" value="<%= user.name || '' %>" required>
                </div>

                <div class="form-group">
                    <label><%= t('a.prof_username') %></label>
                    <input type="text" name="username" value="<%= user.username %>" required>
                </div>

                <div class="form-group">
                    <label><%= t('a.prof_newpass') %></label>
                    <input type="password" name="password">
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;"><%= t('a.update') %></button>
            </form>

            <hr style="margin: 30px 0; border-color: var(--border);">

            <div style="text-align: center;">
                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">
                    <%= t('a.prof_delete_warn') %>
                </p>
                <form action="/admin/profile/delete" method="POST"
                    data-confirm="<%= t('a.prof_delete_confirm') %>">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-outline"
                        style="color: #ef4444; border-color: #ef4444; width: 100%;"><%= t('a.prof_delete_btn') %></button>
                </form>
            </div>
        </div>
    </main>

<script nonce="<%= cspNonce %>">
document.querySelectorAll('form[data-confirm]').forEach(f => {
    f.addEventListener('submit', (e) => { if (!confirm(f.dataset.confirm)) e.preventDefault(); });
});
</script>

<%- include('partials/footer') %>