<%- include('partials/header') %>

    <main class="container admin-main" style="max-width: 600px;">
        <div class="section-header">
            <h2 class="section-title">Profilimi Düzenle</h2>
        </div>

        <div class="contact-card">
            <form action="/admin/profile" method="POST">
                <div class="form-group">
                    <label>Ad Soyad</label>
                    <input type="text" name="name" value="<%= user.name || '' %>" required>
                </div>

                <div class="form-group">
                    <label>Kullanıcı Adı</label>
                    <input type="text" name="username" value="<%= user.username %>" required>
                </div>

                <div class="form-group">
                    <label>Yeni Şifre (Değiştirmek istemiyorsanız boş bırakın)</label>
                    <input type="password" name="password">
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Güncelle</button>
            </form>

            <hr style="margin: 30px 0; border-color: var(--border);">

            <div style="text-align: center;">
                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">
                    Hesabınızı sildiğinizde yayınladığınız tüm makaleler de silinecektir. Bu işlem geri alınamaz.
                </p>
                <form action="/admin/profile/delete" method="POST"
                    onsubmit="return confirm('Hesabınızı ve tüm verilerinizi kalıcı olarak silmek istediğinize emin misiniz?');">
                    <button type="submit" class="btn btn-outline"
                        style="color: #ef4444; border-color: #ef4444; width: 100%;">Hesabımı Sil</button>
                </form>
            </div>
        </div>
    </main>

<%- include('partials/footer') %>