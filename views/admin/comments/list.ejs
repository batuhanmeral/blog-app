<%- include('../partials/header') %>

    <main class="container admin-main">
        <div class="section-header" style="margin-bottom: 20px;">
            <h2 class="section-title" style="font-size: 1.8rem; margin: 0;"><%= t('a.cm_title') %></h2>
        </div>

        <% if (locals.flash && flash.success) { %>
            <div style="background: rgba(16,185,129,.1); border:1px solid #10b981; color:#10b981; padding:10px; border-radius:8px; margin-bottom:15px;"><%= flash.success %></div>
        <% } %>
        <% if (locals.flash && flash.error) { %>
            <div style="background: rgba(239,68,68,.1); border:1px solid #ef4444; color:#ef4444; padding:10px; border-radius:8px; margin-bottom:15px;"><%= flash.error %></div>
        <% } %>

        <div class="filter-tabs" style="display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap;">
            <a href="/admin/comments?status=pending" class="filter-tab <%= status === 'pending' ? 'active' : '' %>"><%= t('a.cm_pending') %> (<%= counts.pending %>)</a>
            <a href="/admin/comments?status=approved" class="filter-tab <%= status === 'approved' ? 'active' : '' %>"><%= t('a.cm_approved') %> (<%= counts.approved %>)</a>
            <a href="/admin/comments?status=spam" class="filter-tab <%= status === 'spam' ? 'active' : '' %>"><%= t('a.cm_spam') %> (<%= counts.spam %>)</a>
        </div>

        <% if (comments.length === 0) { %>
            <p style="text-align:center; color: var(--text-muted); padding: 40px 0;"><%= t('a.cm_empty') %></p>
        <% } else { %>
            <div class="comment-mod-list">
                <% comments.forEach(c => { %>
                    <div class="comment-mod">
                        <div class="comment-mod-meta">
                            <strong><%= c.name %></strong>
                            <% if (c.email) { %><span class="muted"><%= c.email %></span><% } %>
                            <span class="muted">· <%= new Date(c.createdAt).toLocaleString(locale === 'en' ? 'en-US' : 'tr-TR') %></span>
                            <% if (c.post) { %>
                                <span class="muted">· <a href="/blog/<%= c.post._id %>#yorumlar" target="_blank"><%= c.post.title %></a></span>
                            <% } %>
                        </div>
                        <p class="comment-mod-body"><%= c.body %></p>
                        <div class="comment-mod-actions">
                            <% if (status !== 'approved') { %>
                            <form action="/admin/comments/<%= c._id %>/approve" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="from" value="<%= status %>">
                                <button type="submit" class="btn-mod approve"><%= t('a.cm_approve') %></button>
                            </form>
                            <% } %>
                            <% if (status !== 'spam') { %>
                            <form action="/admin/comments/<%= c._id %>/spam" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="from" value="<%= status %>">
                                <button type="submit" class="btn-mod spam"><%= t('a.cm_spam_btn') %></button>
                            </form>
                            <% } %>
                            <form action="/admin/comments/delete/<%= c._id %>" method="POST" data-confirm="<%= t('a.cm_confirm') %>">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="from" value="<%= status %>">
                                <button type="submit" class="btn-mod delete"><%= t('a.cm_delete') %></button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <style>
        .filter-tab { padding: 8px 16px; border-radius: 8px; background: var(--bg-card); color: var(--text-muted); font-size: 14px; }
        .filter-tab.active { background: var(--primary-color); color: #fff; }
        .comment-mod-list { display: flex; flex-direction: column; gap: 12px; }
        .comment-mod { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
        .comment-mod-meta { font-size: 14px; margin-bottom: 8px; }
        .comment-mod-meta .muted { color: var(--text-muted); font-size: 13px; }
        .comment-mod-meta a { color: var(--primary-color); }
        .comment-mod-body { margin: 0 0 12px; white-space: pre-wrap; color: var(--text-main); }
        .comment-mod-actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .comment-mod-actions form { margin: 0; }
        .btn-mod { padding: 6px 14px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text-main); cursor: pointer; font-size: 13px; }
        .btn-mod.approve:hover { background: #10b981; border-color: #10b981; color: #fff; }
        .btn-mod.spam:hover { background: #f59e0b; border-color: #f59e0b; color: #fff; }
        .btn-mod.delete:hover { background: #ef4444; border-color: #ef4444; color: #fff; }
    </style>

    <script nonce="<%= cspNonce %>">
        document.querySelectorAll('form[data-confirm]').forEach(f => {
            f.addEventListener('submit', (e) => { if (!confirm(f.dataset.confirm)) e.preventDefault(); });
        });
    </script>

<%- include('../partials/footer') %>
