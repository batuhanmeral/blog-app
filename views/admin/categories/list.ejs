<%- include('../partials/header') %>

<main class="container admin-main">
    <div class="admin-header">
        <h1>Kategoriler</h1>
        <a href="/admin/categories/add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Kategori
        </a>
    </div>

    <div class="admin-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Renk</th>
                    <th>Kategori Adı</th>
                    <th>Slug</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(category => { %>
                    <tr>
                        <td>
                            <span class="tag-color-preview" style="background-color: <%= category.color %>"></span>
                        </td>
                        <td>
                            <span class="tag-badge" style="background-color: <%= category.color %>">
                                <%= category.name %>
                            </span>
                        </td>
                        <td><code><%= category.slug %></code></td>
                        <td class="actions">
                            <a href="/admin/categories/edit/<%= category.id %>" class="btn btn-sm btn-edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form action="/admin/categories/delete/<%= category.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-delete" onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="text-center">Henüz kategori eklenmemiş.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>

<style>
.admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}
.admin-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
}
.tag-color-preview {
    display: inline-block;
    width: 24px;
    height: 24px;
    border-radius: 4px;
    vertical-align: middle;
}
.tag-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
}
.actions {
    display: flex;
    gap: 8px;
}
.btn-sm {
    padding: 6px 10px;
    font-size: 12px;
}
</style>

<%- include('../partials/footer') %>
