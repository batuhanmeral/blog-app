<%- include('../partials/header') %>

<main class="container admin-main" style="max-width:600px;">
    <div class="section-header"><h2 class="section-title"><%= t('a.u_edit_title') %></h2></div>

    <div class="contact-card">
        <form action="/admin/users/edit/<%= editUser._id %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group"><label><%= t('a.u_username') %></label><input type="text" value="<%= editUser.username %>" disabled></div>
            <div class="form-group"><label><%= t('a.u_name') %></label><input type="text" name="name" value="<%= editUser.name || '' %>"></div>
            <div class="form-group">
                <label><%= t('a.u_role') %></label>
                <select name="role">
                    <% roles.forEach(r => { %>
                        <option value="<%= r %>" <%= editUser.role === r ? 'selected' : '' %>><%= r %></option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group">
                <label><%= t('a.u_newpass') %></label>
                <input type="password" name="password">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;"><%= t('a.update') %></button>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>
