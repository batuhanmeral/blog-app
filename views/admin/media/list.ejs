<%- include('../partials/header') %>

    <main class="container admin-main">
        <div class="section-header"
            style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
            <div>
                <h2 class="section-title"><%= t('a.media_title') %></h2>
                <p class="section-subtitle"><%= t('a.media_total', { n: total }) %></p>
            </div>
            <button type="button" class="btn btn-primary" id="open-upload-modal">
                <i class="fas fa-upload"></i> <%= t('a.media_new') %>
            </button>
        </div>

        <% if (typeof successMessage !=='undefined' && successMessage) { %>
            <div class="alert alert-success" style="margin-bottom: 20px;">
                <%= successMessage %>
            </div>
            <% } %>
                <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                    <div class="alert alert-error" style="margin-bottom: 20px;">
                        <%= errorMessage %>
                    </div>
                    <% } %>

                        <div class="media-grid">
                            <% if (media.length===0) { %>
                                <div class="empty-state">
                                    <i class="fas fa-images"></i>
                                    <p><%= t('a.media_empty') %></p>
                                </div>
                                <% } else { %>
                                    <% media.forEach(item=> { %>
                                        <div class="media-card" data-id="<%= item._id %>">
                                            <div class="media-preview">
                                                <img src="<%= item.url %>" alt="<%= item.alt || item.originalName %>"
                                                    loading="lazy">
                                            </div>
                                            <div class="media-info">
                                                <span class="media-name" title="<%= item.originalName %>">
                                                    <%= item.originalName %>
                                                </span>
                                                <span class="media-size">
                                                    <%= item.formatSize() %>
                                                </span>
                                            </div>
                                            <div class="media-actions">
                                                <button type="button" class="btn-icon" data-copy-url="<%= item.url %>"
                                                    title="<%= t('a.media_copy') %>">
                                                    <i class="fas fa-copy"></i>
                                                </button>
                                                <form action="/admin/media/delete/<%= item._id %>" method="POST"
                                                    style="display: inline;"
                                                    data-confirm="<%= t('a.media_confirm') %>">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" class="btn-icon btn-danger" title="<%= t('a.bulk_delete') %>">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } %>
                        </div>

                        <% if (totalPages> 1) { %>
                            <div class="pagination">
                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/media?page=<%= i %>"
                                        class="page-btn <%= currentPage === i ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                            </div>
                            <% } %>
    </main>

    <!-- Upload Modal -->
    <dialog id="upload-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><%= t('a.media_upload') %></h3>
                <button type="button" class="modal-close" id="close-upload-modal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div id="drop-zone" class="drop-zone">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <p><%= t('a.media_drop') %></p>
                    <label class="btn btn-outline" for="file-input"><%= t('a.media_choose') %></label>
                    <input type="file" id="file-input" accept="image/*" multiple hidden>
                </div>
                <div id="upload-progress" class="upload-progress" style="display: none;">
                    <div class="progress-bar">
                        <div class="progress-fill"></div>
                    </div>
                    <p class="progress-text"><%= t('a.media_uploading') %></p>
                </div>
                <div id="upload-results" class="upload-results"></div>
            </div>
        </div>
    </dialog>

    <style>
        .media-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .media-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.2s;
        }

        .media-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
            border-color: var(--primary-color);
        }

        .media-preview {
            aspect-ratio: 1;
            overflow: hidden;
            background: rgba(0, 0, 0, 0.2);
        }

        .media-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }

        .media-card:hover .media-preview img {
            transform: scale(1.05);
        }

        .media-info {
            padding: 12px;
            border-top: 1px solid var(--border);
        }

        .media-name {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .media-size {
            font-size: 11px;
            color: var(--text-muted);
        }

        .media-actions {
            display: flex;
            gap: 8px;
            padding: 0 12px 12px;
        }

        .btn-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-icon:hover {
            background: var(--primary-color);
            color: #000;
            border-color: var(--primary-color);
        }

        .btn-icon.btn-danger:hover {
            background: #ef4444;
            border-color: #ef4444;
            color: white;
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        /* Modal Styles */
        .modal {
            border: none;
            border-radius: 16px;
            background: var(--bg-card);
            padding: 0;
            max-width: 500px;
            width: 90%;
        }

        .modal::backdrop {
            background: rgba(0, 0, 0, 0.7);
        }

        .modal-content {
            padding: 24px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-header h3 {
            color: var(--text-main);
            margin: 0;
        }

        .modal-close {
            background: transparent;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

        .drop-zone {
            border: 2px dashed var(--border);
            border-radius: 12px;
            padding: 40px 20px;
            text-align: center;
            transition: all 0.2s;
        }

        .drop-zone.dragover {
            border-color: var(--primary-color);
            background: rgba(16, 185, 129, 0.1);
        }

        .drop-zone i {
            font-size: 48px;
            color: var(--primary-color);
            margin-bottom: 16px;
        }

        .drop-zone p {
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .upload-progress {
            margin-top: 20px;
        }

        .progress-bar {
            height: 8px;
            background: var(--border);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: var(--primary-color);
            width: 0%;
            transition: width 0.3s;
        }

        .progress-text {
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 8px;
        }

        .upload-results {
            margin-top: 20px;
        }

        .upload-results .success {
            color: var(--primary-color);
        }

        .upload-results .error {
            color: #ef4444;
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 20px;
        }

        .page-btn {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            transition: all 0.2s;
        }

        .page-btn:hover,
        .page-btn.active {
            background: var(--primary-color);
            color: #000;
            border-color: var(--primary-color);
        }
    </style>

    <script nonce="<%= cspNonce %>">
        const uploadModal = document.getElementById('upload-modal');
        document.getElementById('open-upload-modal').addEventListener('click', () => uploadModal.showModal());
        document.getElementById('close-upload-modal').addEventListener('click', () => uploadModal.close());

        document.querySelectorAll('[data-copy-url]').forEach(btn => {
            btn.addEventListener('click', () => {
                navigator.clipboard.writeText(window.location.origin + btn.dataset.copyUrl);
                alert('URL kopyalandı!');
            });
        });

        document.querySelectorAll('form[data-confirm]').forEach(f => {
            f.addEventListener('submit', (e) => {
                if (!confirm(f.dataset.confirm)) e.preventDefault();
            });
        });

        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        const progressDiv = document.getElementById('upload-progress');
        const resultsDiv = document.getElementById('upload-results');

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });

        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });

        async function handleFiles(files) {
            progressDiv.style.display = 'block';
            resultsDiv.innerHTML = '';

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const formData = new FormData();
                formData.append('file', file);

                try {
                    const res = await fetch('/admin/media/upload', {
                        method: 'POST',
                        headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
                        body: formData
                    });
                    const data = await res.json();

                    if (data.success) {
                        resultsDiv.innerHTML += `<p class="success">✓ ${file.name} yüklendi</p>`;
                    } else {
                        resultsDiv.innerHTML += `<p class="error">✗ ${file.name}: ${data.error}</p>`;
                    }
                } catch (err) {
                    resultsDiv.innerHTML += `<p class="error">✗ ${file.name}: Hata oluştu</p>`;
                }

                document.querySelector('.progress-fill').style.width = `${((i + 1) / files.length) * 100}%`;
            }

            setTimeout(() => location.reload(), 1500);
        }
    </script>

    <%- include('../partials/footer') %>