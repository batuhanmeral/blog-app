<%- include('partials/header') %>

    <main class="container admin-main">
        <div class="section-header">
            <h2 class="section-title"><%= t('a.dash_title') %></h2>
            <p class="section-subtitle"><%= t('a.dash_welcome') %>, <%= user.name || user.username %>
            </p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--primary-color);">
                    <i class="fas fa-newspaper"></i>
                </div>
                <div class="stat-content">
                    <h3>
                        <%= stats.posts %>
                    </h3>
                    <p><%= t('a.dash_posts') %></p>
                </div>
                <a href="/admin/posts" class="stat-link"><%= t('a.manage') %></a>
            </div>

            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                    <i class="fas fa-eye"></i>
                </div>
                <div class="stat-content">
                    <h3>
                        <%= stats.totalViews.toLocaleString(locale === 'en' ? 'en-US' : 'tr-TR') %>
                    </h3>
                    <p><%= t('a.dash_views') %></p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(236, 72, 153, 0.1); color: #ec4899;">
                    <i class="fas fa-tags"></i>
                </div>
                <div class="stat-content">
                    <h3>
                        <%= stats.categories %>
                    </h3>
                    <p><%= t('a.dash_categories') %></p>
                </div>
                <a href="/admin/categories" class="stat-link"><%= t('a.manage') %></a>
            </div>

            <% if (user && (user.role === 'admin' || user.role === 'editor')) { %>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="stat-content">
                    <h3>
                        <%= stats.messages %>
                    </h3>
                    <p><%= t('a.dash_messages') %></p>
                </div>
                <a href="/admin/messages" class="stat-link"><%= t('a.view_link') %></a>
            </div>
            <% } %>

            <% if (user && (user.role === 'admin' || user.role === 'editor')) { %>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(168, 85, 247, 0.1); color: #a855f7;">
                    <i class="fas fa-comments"></i>
                </div>
                <div class="stat-content">
                    <h3>
                        <%= stats.comments %>
                        <% if (stats.pendingComments > 0) { %>
                        <span class="pending-badge"><%= stats.pendingComments %> <%= t('a.dash_pending') %></span>
                        <% } %>
                    </h3>
                    <p><%= t('a.dash_comments') %></p>
                </div>
                <a href="/admin/comments" class="stat-link"><%= t('a.view_link') %></a>
            </div>
            <% } %>

            <% if (user && user.role === 'admin') { %>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(251, 146, 60, 0.1); color: #fb923c;">
                    <i class="fas fa-history"></i>
                </div>
                <div class="stat-content">
                    <h3><%= stats.auditLogs %></h3>
                    <p><%= t('a.dash_audit') %></p>
                </div>
                <a href="/admin/audit" class="stat-link"><%= t('a.view_link') %></a>
            </div>
            <% } %>

            <% if (user && user.role === 'admin') { %>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3><%= stats.users %></h3>
                    <p><%= t('a.dash_users') %></p>
                </div>
                <a href="/admin/users" class="stat-link"><%= t('a.manage') %></a>
            </div>
            <% } %>
        </div>

        <% if (locals.traffic && traffic.length > 0) { %>
        <% const maxT = Math.max(1, ...traffic.map(t => t.count)); %>
        <% const W = 720, H = 160, padL = 30, padB = 20; %>
        <% const innerW = W - padL - 10, innerH = H - padB - 10; %>
        <% const step = innerW / Math.max(1, traffic.length - 1); %>
        <% const points = traffic.map((t, i) => `${padL + i * step},${10 + innerH - (t.count / maxT) * innerH}`).join(' '); %>
        <section class="chart-card">
            <h3><%= t('a.dash_traffic') %> <small style="color:var(--text-muted); font-weight:normal;"><%= t('a.dash_traffic_total', { n: traffic.reduce((a,b)=>a+b.count,0) }) %></small></h3>
            <svg viewBox="0 0 <%= W %> <%= H %>" style="width:100%; height:auto;" preserveAspectRatio="none">
                <polyline fill="none" stroke="#10b981" stroke-width="2" points="<%= points %>" />
                <% traffic.forEach((t, i) => { %>
                    <circle cx="<%= padL + i * step %>" cy="<%= 10 + innerH - (t.count / maxT) * innerH %>" r="2" fill="#10b981">
                        <title><%= t.day %>: <%= t.count %> görüntülenme</title>
                    </circle>
                <% }) %>
                <text x="<%= padL %>" y="<%= H - 5 %>" font-size="10" fill="#94a3b8"><%= traffic[0].day %></text>
                <text x="<%= W - 60 %>" y="<%= H - 5 %>" font-size="10" fill="#94a3b8"><%= traffic[traffic.length-1].day %></text>
            </svg>
        </section>
        <% } %>

        <% if (locals.categoryCounts && categoryCounts.length > 0) { %>
        <% const maxC = Math.max(1, ...categoryCounts.map(c => c.count)); %>
        <section class="chart-card">
            <h3><%= t('a.dash_cat_chart') %></h3>
            <div class="cat-bars">
                <% categoryCounts.forEach(c => { %>
                    <div class="cat-bar">
                        <span class="cat-bar-label" style="background:<%= c.color %>;"><%= c.name %></span>
                        <div class="cat-bar-track">
                            <div class="cat-bar-fill" style="width: <%= (c.count / maxC * 100).toFixed(1) %>%; background:<%= c.color %>;"></div>
                        </div>
                        <span class="cat-bar-count"><%= c.count %></span>
                    </div>
                <% }) %>
            </div>
        </section>
        <% } %>

    </main>

    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }
        @media (max-width: 1000px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 560px) {
            .stats-grid { grid-template-columns: 1fr; }
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .stat-content h3 {
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
        }

        .stat-content p {
            margin: 0;
            color: var(--text-muted);
            font-size: 14px;
        }

        .stat-link {
            color: var(--primary-color);
            font-size: 14px;
            font-weight: 500;
            margin-top: auto;
        }
        .pending-badge {
            display: inline-block;
            vertical-align: middle;
            font-size: 11px;
            font-weight: 600;
            color: #fb923c;
            background: rgba(251, 146, 60, 0.12);
            border: 1px solid rgba(251, 146, 60, 0.4);
            border-radius: 999px;
            padding: 2px 8px;
            margin-left: 8px;
        }
        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .chart-card h3 { margin-top: 0; }
        .cat-bars { display: flex; flex-direction: column; gap: 10px; }
        .cat-bar { display: grid; grid-template-columns: 140px 1fr 40px; gap: 10px; align-items: center; }
        .cat-bar-label { padding: 4px 10px; border-radius: 12px; color: #fff; font-size: 12px; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .cat-bar-track { background: rgba(255,255,255,0.05); border-radius: 4px; height: 12px; overflow: hidden; }
        .cat-bar-fill { height: 100%; }
        .cat-bar-count { color: var(--text-muted); font-size: 13px; text-align: right; }
    </style>

    <%- include('partials/footer') %>