# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Reverse proxy (Nginx/Docker/PaaS) arkasında gerçek istemci IP'si için.
# Sayı (hop sayısı, örn. 1), "true", "false" veya özel değer. Boş bırakılırsa
# production'da 1, aksi halde kapalı. req.ip'ye bağlı rate-limit ve IP hash'leri
# doğru çalışması için proxy arkasında ayarlayın.
TRUST_PROXY=

# Database
MONGODB_URI=mongodb://localhost:27017/crypton

# Session — production'da mutlaka uzun, rastgele bir değerle değiştirin
SESSION_SECRET=change-this-to-a-long-random-string

# Admin panel giriş yolu (/admin/<path>)
ADMIN_LOGIN_PATH=login

# Yüklenen dosyaların tutulacağı kalıcı dizin (boşsa public/assets/uploads)
DATA_PATH=

# Log seviyesi: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# 2FA (TOTP) uygulamasında görünecek yayıncı adı
TOTP_ISSUER=Crypton

# Kanonik site adresi (RSS, sitemap, canonical/OG URL'leri için)
SITE_URL=http://localhost:3000
